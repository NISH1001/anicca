{
  "manifest_version": 3,
  "name": "anicca — new tab",
  "version": "0.1.0",
  "description": "Your new tab as a live meditation on impermanence — the waking hours you still have, rendered as light against the dark.",
  "browser_specific_settings": {
    "gecko": {
      "id": "anicca@nishparadox.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/anicca.svg",
    "96": "icons/anicca.svg",
    "128": "icons/anicca.svg"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; img-src 'self' data:; style-src 'self'; font-src 'self'"
  }
}
